## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Folder named bin
bin/
obj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# NuGet Packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# Database files
*.db
*.db-shm
*.db-wal

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

# Visual Studio Code
.vscode/
*.code-workspace

# macOS
.DS_Store

# Node modules
node_modules/
